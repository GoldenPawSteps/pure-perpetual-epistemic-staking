{
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["ES2023"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "types": ["node"],
    "skipLibCheck": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "rootDir": ".",
    "outDir": "dist-server",
    "esModuleInterop": true,
    "verbatimModuleSyntax": true,
    "rewriteRelativeImportExtensions": true
  },
  "include": ["server/**/*.ts", "src/initialState.ts", "src/math.ts", "src/stateValidation.ts", "src/types.ts"],
  "exclude": ["server/**/*.test.ts"]
}